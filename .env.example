# FalkorDB — path to the Unix socket created by CodeGraphContext
FALKORDB_SOCKET=/root/.codegraphcontext/global/db/falkordb.sock

# Name of the graph inside FalkorDB (set during cgc index)
CGC_GRAPH_NAME=codegraph

# Google Cloud project for Vertex AI / Gemini
GEMINI_PROJECT=your-gcp-project-id
GEMINI_LOCATION=us-central1
